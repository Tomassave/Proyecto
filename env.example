# ── Base de datos PostgreSQL ──────────────────────────────────
# Si falla la conexión en Windows, prueba: DB_HOST=127.0.0.1
# Docker (recomendado): docker compose up -d   luego: npm run db:init
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=sabana_market
DB_USER=postgres
DB_PASSWORD=postgres

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=cambia_este_secreto_en_produccion_min32chars
JWT_EXPIRES_IN=24h

# ── Servidor ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
