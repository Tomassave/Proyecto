{
  "name": "sabana-market-backend",
  "version": "1.0.0",
  "description": "API REST Sabana Marketplace – TKT-01 al TKT-07",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "db:init": "node src/config/db.init.js",
    "db:docker-up": "docker compose up -d",
    "db:wait": "node scripts/wait-postgres.js",
